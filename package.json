{
  "name": "nvimse",
  "displayName": "nvimse — No Vibe In My (VS Code) Editor",
  "description": "The nvime discipline lane, ported (under protest) to VS Code. The AI keeps its hands off your code until you tell it exactly where, how, and why.",
  "version": "0.3.0",
  "publisher": "mengsig",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "claude",
    "codex",
    "ai",
    "diff review",
    "no vibe coding"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mengsig/nvimse"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      { "command": "nvimse.dashboard", "title": "nvimse: Command Center", "category": "nvimse" },
      { "command": "nvimse.chat", "title": "nvimse: Chat Conversations", "category": "nvimse" },
      { "command": "nvimse.chats", "title": "nvimse: Conversation Picker", "category": "nvimse" },
      { "command": "nvimse.review", "title": "nvimse: Review / Docs", "category": "nvimse" },
      { "command": "nvimse.reviewNow", "title": "nvimse: Review Worktree Diff Now", "category": "nvimse" },
      { "command": "nvimse.edit", "title": "nvimse: Edit Selection / Function", "category": "nvimse" },
      { "command": "nvimse.ask", "title": "nvimse: Ask About Selection / Function", "category": "nvimse" },
      { "command": "nvimse.quickFix", "title": "nvimse: Quick Fix", "category": "nvimse" },
      { "command": "nvimse.send", "title": "nvimse: Send File / Range to Conversation", "category": "nvimse" },
      { "command": "nvimse.last", "title": "nvimse: Reopen Last Conversation", "category": "nvimse" },
      { "command": "nvimse.provider", "title": "nvimse: Choose Provider", "category": "nvimse" },
      { "command": "nvimse.model", "title": "nvimse: Choose Model", "category": "nvimse" },
      { "command": "nvimse.accept", "title": "nvimse: Accept Diff Block", "category": "nvimse" },
      { "command": "nvimse.acceptForce", "title": "nvimse: Force-Accept Diff Block", "category": "nvimse" },
      { "command": "nvimse.acceptAll", "title": "nvimse: Accept All Diff Blocks", "category": "nvimse" },
      { "command": "nvimse.acceptAllForce", "title": "nvimse: Force-Accept All Diff Blocks", "category": "nvimse" },
      { "command": "nvimse.reject", "title": "nvimse: Reject Diff Block", "category": "nvimse" },
      { "command": "nvimse.rejectAll", "title": "nvimse: Reject All Diff Blocks", "category": "nvimse" },
      { "command": "nvimse.undoAccept", "title": "nvimse: Undo Last Accepted Block", "category": "nvimse" },
      { "command": "nvimse.perf", "title": "nvimse: Benchmark & Optimize Selection", "category": "nvimse" },
      { "command": "nvimse.attributeToggle", "title": "nvimse: Toggle Attribution Overlay", "category": "nvimse" },
      { "command": "nvimse.planAddTest", "title": "nvimse: Scaffold Regression Test for Step", "category": "nvimse" },
      { "command": "nvimse.nextBlock", "title": "nvimse: Next Diff Block", "category": "nvimse" },
      { "command": "nvimse.prevBlock", "title": "nvimse: Previous Diff Block", "category": "nvimse" },
      { "command": "nvimse.diff", "title": "nvimse: Open Diff Review Workspace", "category": "nvimse" },
      { "command": "nvimse.discussDiff", "title": "nvimse: Discuss Active Diff", "category": "nvimse" },
      { "command": "nvimse.audit", "title": "nvimse: Open Audit Log", "category": "nvimse" },
      { "command": "nvimse.auditSummary", "title": "nvimse: Audit Summary", "category": "nvimse" },
      { "command": "nvimse.auditForces", "title": "nvimse: Audit Force-Accepts", "category": "nvimse" },
      { "command": "nvimse.attribute", "title": "nvimse: Show Attribution for Line", "category": "nvimse" },
      { "command": "nvimse.attributeShow", "title": "nvimse: Show Attribution Overlay", "category": "nvimse" },
      { "command": "nvimse.attributeHide", "title": "nvimse: Hide Attribution Overlay", "category": "nvimse" },
      { "command": "nvimse.blame", "title": "nvimse: Blame Current Line", "category": "nvimse" },
      { "command": "nvimse.recap", "title": "nvimse: Recap Changes", "category": "nvimse" },
      { "command": "nvimse.mcp", "title": "nvimse: MCP Servers", "category": "nvimse" },
      { "command": "nvimse.testLoop", "title": "nvimse: Configure Test Loop", "category": "nvimse" },
      { "command": "nvimse.plan", "title": "nvimse: Plans", "category": "nvimse" },
      { "command": "nvimse.planNew", "title": "nvimse: New Plan", "category": "nvimse" },
      { "command": "nvimse.planFocus", "title": "nvimse: Focus Plan UI", "category": "nvimse" },
      { "command": "nvimse.planClose", "title": "nvimse: Close Plan UI", "category": "nvimse" },
      { "command": "nvimse.usage", "title": "nvimse: Token + Cost Usage", "category": "nvimse" },
      { "command": "nvimse.hooks", "title": "nvimse: Git Hooks", "category": "nvimse" },
      { "command": "nvimse.pr", "title": "nvimse: PR Sidecar", "category": "nvimse" },
      { "command": "nvimse.policy", "title": "nvimse: Policy Rules", "category": "nvimse" },
      { "command": "nvimse.cancel", "title": "nvimse: Cancel Active Agent", "category": "nvimse" },
      { "command": "nvimse.disable", "title": "nvimse: Disable", "category": "nvimse" },
      { "command": "nvimse.enable", "title": "nvimse: Enable", "category": "nvimse" },
      { "command": "nvimse.bigChange", "title": "nvimse: Big Change", "category": "nvimse" },
      { "command": "nvimse.bigChangeNew", "title": "nvimse: New Big Change", "category": "nvimse" },
      { "command": "nvimse.health", "title": "nvimse: Check Health", "category": "nvimse" }
    ],
    "keybindings": [
      { "command": "nvimse.dashboard", "key": "ctrl+k space", "mac": "cmd+k space", "when": "editorTextFocus || !editorTextFocus" },
      { "command": "nvimse.edit", "key": "ctrl+k ctrl+e", "mac": "cmd+k cmd+e" },
      { "command": "nvimse.ask", "key": "ctrl+k ctrl+a", "mac": "cmd+k cmd+a" },
      { "command": "nvimse.quickFix", "key": "ctrl+k ctrl+f", "mac": "cmd+k cmd+f" },
      { "command": "nvimse.chat", "key": "ctrl+k ctrl+c", "mac": "cmd+k cmd+c" },
      { "command": "nvimse.accept", "key": "ctrl+k a", "mac": "cmd+k a", "when": "nvimse.diffActive && editorTextFocus" },
      { "command": "nvimse.acceptAll", "key": "ctrl+k shift+a", "mac": "cmd+k shift+a", "when": "nvimse.diffActive && editorTextFocus" },
      { "command": "nvimse.reject", "key": "ctrl+k r", "mac": "cmd+k r", "when": "nvimse.diffActive && editorTextFocus" },
      { "command": "nvimse.rejectAll", "key": "ctrl+k shift+r", "mac": "cmd+k shift+r", "when": "nvimse.diffActive && editorTextFocus" },
      { "command": "nvimse.nextBlock", "key": "ctrl+k ]", "mac": "cmd+k ]", "when": "nvimse.diffActive && editorTextFocus" },
      { "command": "nvimse.prevBlock", "key": "ctrl+k [", "mac": "cmd+k [", "when": "nvimse.diffActive && editorTextFocus" },
      { "command": "nvimse.undoAccept", "key": "ctrl+k u", "mac": "cmd+k u", "when": "nvimse.diffActive && editorTextFocus" },
      { "command": "nvimse.discussDiff", "key": "ctrl+k c", "mac": "cmd+k c", "when": "nvimse.diffActive && editorTextFocus" }
    ],
    "menus": {
      "editor/context": [
        { "command": "nvimse.ask", "group": "nvimse@1", "when": "editorHasSelection" },
        { "command": "nvimse.edit", "group": "nvimse@2", "when": "editorHasSelection" },
        { "command": "nvimse.quickFix", "group": "nvimse@3", "when": "editorHasSelection" },
        { "command": "nvimse.perf", "group": "nvimse@4", "when": "editorHasSelection" },
        { "command": "nvimse.send", "group": "nvimse@5" }
      ]
    },
    "configuration": {
      "title": "nvimse",
      "properties": {
        "nvimse.provider": {
          "type": "string",
          "enum": ["claude", "codex"],
          "default": "claude",
          "description": "Default AI provider."
        },
        "nvimse.providers.claude.cmd": { "type": "string", "default": "claude" },
        "nvimse.providers.claude.models": { "type": "array", "default": ["opus", "sonnet", "haiku"] },
        "nvimse.providers.codex.cmd": { "type": "string", "default": "codex" },
        "nvimse.providers.codex.models": { "type": "array", "default": ["gpt-5.5", "gpt-5.4", "gpt-5.4-mini", "gpt-5.3-codex-spark"] },
        "nvimse.providers.codex.reasoningEffort": { "type": ["string", "null"], "default": null },
        "nvimse.audit.enabled": { "type": "boolean", "default": true },
        "nvimse.audit.path": { "type": ["string", "null"], "default": null },
        "nvimse.audit.logPrompts": { "type": "boolean", "default": false },
        "nvimse.attribution.enabled": { "type": "boolean", "default": true },
        "nvimse.attribution.path": { "type": ["string", "null"], "default": null },
        "nvimse.attribution.max": { "type": "number", "default": 500 },
        "nvimse.recap.autoOpen": { "type": "boolean", "default": true },
        "nvimse.review.allowShell": { "type": "boolean", "default": true },
        "nvimse.review.allowWeb": { "type": "boolean", "default": true },
        "nvimse.review.allowMarkdownWrites": { "type": "boolean", "default": true },
        "nvimse.selection.allowShell": { "type": "boolean", "default": true },
        "nvimse.selection.allowWeb": { "type": "boolean", "default": true },
        "nvimse.edit.contextLines": { "type": "number", "default": 0 },
        "nvimse.edit.injectContext": { "type": "boolean", "default": true },
        "nvimse.edit.contextMaxChars": { "type": "number", "default": 6000 },
        "nvimse.edit.relatedTestLimit": { "type": "number", "default": 4 },
        "nvimse.edit.symbolLimit": { "type": "number", "default": 24 },
        "nvimse.edit.recentDiffLimit": { "type": "number", "default": 5 },
        "nvimse.edit.maxTurns": { "type": ["number", "null"], "default": null },
        "nvimse.diff.maxVisualBlockLines": { "type": "number", "default": 12 },
        "nvimse.diff.devilsAdvocate": { "type": "boolean", "default": false },
        "nvimse.verify.enabled": { "type": "boolean", "default": true },
        "nvimse.verify.blockOnParseError": { "type": "boolean", "default": true },
        "nvimse.verify.timeoutMs": { "type": "number", "default": 8000 },
        "nvimse.verify.externalChecks": { "type": "boolean", "default": false },
        "nvimse.verify.checks": { "type": "object", "default": {} },
        "nvimse.risk.enabled": { "type": "boolean", "default": true },
        "nvimse.risk.sensitivePaths": { "type": ["array", "null"], "default": null },
        "nvimse.risk.generatedGlobs": { "type": ["array", "null"], "default": null },
        "nvimse.risk.confirmOnForceHigh": { "type": "boolean", "default": true },
        "nvimse.policyRules.enabled": { "type": "boolean", "default": true },
        "nvimse.policyRules.path": { "type": ["string", "null"], "default": null },
        "nvimse.intent.enabled": { "type": "boolean", "default": true },
        "nvimse.intent.minWords": { "type": "number", "default": 4 },
        "nvimse.intent.classifier": { "type": "string", "enum": ["heuristic", "model"], "default": "heuristic" },
        "nvimse.pr.enabled": { "type": "boolean", "default": true },
        "nvimse.pr.path": { "type": ["string", "null"], "default": null },
        "nvimse.pr.baseBranch": { "type": ["string", "null"], "default": null },
        "nvimse.pr.includeUnattributed": { "type": "boolean", "default": true },
        "nvimse.chat.maxHistoryMessages": { "type": "number", "default": 24 },
        "nvimse.bigchange.trivial.enabled": { "type": "boolean", "default": true },
        "nvimse.bigchange.trivial.docGlobs": { "type": "array", "default": ["*.md", "*.markdown", "*.rst", "*.txt", "**/*.md", "**/*.markdown", "**/*.rst", "**/*.txt", "docs/**", "doc/**"] },
        "nvimse.plan.enabled": { "type": "boolean", "default": true },
        "nvimse.plan.dir": { "type": ["string", "null"], "default": null },
        "nvimse.plan.autoOpen": { "type": "boolean", "default": true },
        "nvimse.plan.devilsAdvocate": { "type": "boolean", "default": true },
        "nvimse.plan.testRunner": { "type": ["string", "null"], "default": null },
        "nvimse.plan.testFile": { "type": ["string", "null"], "default": null },
        "nvimse.plan.sessionContinuity": { "type": "string", "enum": ["plan", "none"], "default": "plan" },
        "nvimse.sessions.enabled": { "type": "boolean", "default": true },
        "nvimse.sessions.max": { "type": "number", "default": 100 },
        "nvimse.usage.enabled": { "type": "boolean", "default": true },
        "nvimse.usage.maxDays": { "type": "number", "default": 90 },
        "nvimse.usage.statusline": { "type": "boolean", "default": true },
        "nvimse.usage.rates": { "type": "object", "default": {} },
        "nvimse.testLoop.enabled": { "type": "boolean", "default": false },
        "nvimse.testLoop.runner": { "type": ["string", "null"], "default": null },
        "nvimse.testLoop.autoFix": { "type": "boolean", "default": false },
        "nvimse.testLoop.maxRetries": { "type": "number", "default": 2 },
        "nvimse.testLoop.captureLines": { "type": "number", "default": 200 },
        "nvimse.mcp.enabled": { "type": "boolean", "default": true },
        "nvimse.mcp.configPath": { "type": ["string", "null"], "default": null },
        "nvimse.mcp.servers": { "type": "object", "default": {} },
        "nvimse.mcp.exposeSelf": { "type": "boolean", "default": true },
        "nvimse.mcp.codexBypassForMcp": { "type": "boolean", "default": false }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit -p ./",
    "test": "node ./dist/test/runUnit.js",
    "bench": "node ./dist/bench/harness.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
